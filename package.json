{
  "name": "pdf-editor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync-pdf-wasm": "mkdir -p public/wasm && cp node_modules/pdfjs-dist/wasm/openjpeg.wasm node_modules/pdfjs-dist/wasm/qcms_bg.wasm public/wasm/",
    "predev": "pnpm sync-pdf-wasm",
    "dev": "vp dev",
    "prebuild": "pnpm sync-pdf-wasm",
    "build": "tsc && vp build",
    "preview": "vp preview",
    "lint": "vp lint",
    "format": "vp format",
    "test": "vp test"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@paddleocr/paddleocr-js": "^0.4.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "@tanstack/react-virtual": "^3.14.2",
    "docx": "^9.7.1",
    "lucide-react": "^1.17.0",
    "mammoth": "^1.12.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.296",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-pdf": "^10.4.1",
    "react-rnd": "^10.5.3",
    "tesseract.js": "^5.1.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@11.5.2"
}
